{
  "manifest_version": 3,
  "name": "Book Reader",
  "version": "1.0",
  "description": "A Chrome extension to read books online with enhanced features.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Book Reader"
  }
}
